# --- chains ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# --- contracts ---
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
HEALTH_POOLS_ADDRESS=

# --- oracle signer (server only, never commit the real key) ---
ORACLE_SIGNER_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=

# --- Junction (Vital) health data API ---
# Unified API for WHOOP/Oura/Fitbit/Garmin (replaces the WHOOP-direct OAuth).
# Get a key from the Junction dashboard. sk_us_... = US; use sandbox for demos.
JUNCTION_API_KEY=
JUNCTION_BASE_URL=https://api.sandbox.tryvital.io
JUNCTION_REGION=us
JUNCTION_ENV=sandbox

# --- World ID ---
WORLD_APP_ID=
WORLD_ACTION_ID=join-pool
# World ID 4.0 relying-party context (server signs rp_context for the join flow).
# From the "World ID 4.0" tab in the World developer portal:
WORLD_RP_ID=
WORLD_SIGNER_PRIVATE_KEY=

# --- ENS (Sepolia) ---
ENS_PARENT_NAME=
ENS_OWNER_PRIVATE_KEY=

# --- oracle route auth ---
ORACLE_API_SECRET=

# --- Dynamic (wallet/auth) — get from the Dynamic dashboard ---
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
# --- Unlink (private payments) — server only ---
# UNLINK_ENGINE_URL + creds from the Unlink booth/docs (docs.unlink.xyz).
UNLINK_ENGINE_URL=
UNLINK_API_KEY=
UNLINK_ENVIRONMENT=arc-testnet
# Treasury EOA that funds private payouts (server only). May reuse the oracle key.
UNLINK_TREASURY_PRIVATE_KEY=
# BIP-39 mnemonic for the treasury's Unlink shielded account (server only).
UNLINK_TREASURY_MNEMONIC=
# DEPRECATED — remove from your .env.local. Participant accounts are now derived
# client-side from each user's own wallet signature (non-custodial). This var
# was used by the old server-custodial path and is no longer read by any code.
# UNLINK_USER_MASTER_MNEMONIC=
# --- Confidential AI Attester (document-verified health goals) ---
# Live private TEE inference via Chainlink's Confidential AI Attester. The
# document is submitted (POST /api/evidence/submit) and polled by id
# (POST /api/evidence/result). If this key is absent, both routes fall back to a
# deterministic mock verdict (verified=true/high) for the demo.
CONFIDENTIAL_AI_API_KEY=
# Optional override; defaults to https://confidential-ai-dev-preview.cldev.cloud
# CONFIDENTIAL_AI_BASE_URL=

# ANTHROPIC_API_KEY is no longer used — document verification now runs on the
# Confidential AI Attester (above), not the Anthropic/Claude judge.
# ANTHROPIC_API_KEY=

# --- Blink (one-tap USDC top-up on Base Sepolia) ---
# Blink pulls USDC from the user's wallet on Base Sepolia (84532) into the
# merchant address; a confirmed deposit credits the in-app GoHealthMe balance,
# which the user moves to their Arc wallet (treasury-sponsored) to spend on
# pools. Register a sandbox merchant at docs.blink.cash. Server-only keys:
# ECDSA P-256 (prime256v1) PKCS8 PEM; register the matching public key with Blink.
BLINK_MERCHANT_PRIVATE_KEY=
BLINK_MERCHANT_ID=
# Server-only copy of the Base Sepolia receive address (read by the signer route).
BLINK_MERCHANT_ADDRESS=

# --- Treasury (sponsors Arc USDC when a user draws on their balance) ---
# Arc EOA holding USDC; delivers spendable USDC to the user's Arc wallet on a
# balance withdrawal (server only). May reuse the deployer/oracle key.
TREASURY_PRIVATE_KEY=

# --- NEXT_PUBLIC_* aliases (MUST be in app/.env.local, not just here) ---
# The Next app inlines NEXT_PUBLIC_* into the browser bundle ONLY from
# app/.env.local. Server-side vars above are loaded from this repo-root .env via
# next.config.ts (loadRootEnv). These browser-exposed aliases are required:
#   NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID   (Dynamic env id)
#   NEXT_PUBLIC_HEALTH_POOLS_ADDRESS     (= HEALTH_POOLS_ADDRESS)
#   NEXT_PUBLIC_WORLD_APP_ID             (= WORLD_APP_ID)
#   NEXT_PUBLIC_WORLD_ACTION_ID          (= WORLD_ACTION_ID)
#   NEXT_PUBLIC_UNLINK_APP_ID            (Unlink project id — browser-safe, from Unlink dashboard)
#   NEXT_PUBLIC_BLINK_USDC_ADDRESS       (Base Sepolia USDC token address)
#   NEXT_PUBLIC_BLINK_MERCHANT_ADDRESS   (= BLINK_MERCHANT_ADDRESS, Base Sepolia receive addr)
#   NEXT_PUBLIC_BLINK_SIGNER_ENDPOINT    (optional; defaults to /api/blink/sign)
